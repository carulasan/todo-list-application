# System Settings
ENV=development
DEBUG_MODE=true
ALLOWED_HOST=*
CONFIG_NAME=Geoplan-API

# Database Client Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
DATABASE_ENGINE_POOL_SIZE=10
DATABASE_ENGINE_MAX_OVERFLOW=10
DATABASE_ENGINE_POOL_PING=0
READ_DATABASE_URL=postgresql://root:root@geoplan-todo-database:5432/todo
WRITE_DATABASE_URL=postgresql://root:root@geoplan-todo-database:5432/todo
ENABLE_DB_LOGGING=false
